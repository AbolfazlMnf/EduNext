generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// generate 
enum productCategory {
  next
  react 
  vue 
  ang
}
model Products{
  id String @id @default(uuid())
  name String
  category productCategory
  description String
  price Float? @default(0.0)
  images Image[]
}
model Image{
  id String @id @default(uuid())
  image String
  product Products? @relation(fields: [productId],references: [id])
  productId String?
}